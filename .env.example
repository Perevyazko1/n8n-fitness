# Скопируй в .env и заполни: cp .env.example .env

# Адрес, по которому будет доступен n8n.
# На сервере без домена — IP сервера. Локально — localhost.
N8N_HOST=YOUR_SERVER_IP
N8N_PROTOCOL=http
WEBHOOK_URL=http://YOUR_SERVER_IP:5678/

TZ=Europe/Moscow

# Ключ шифрования credentials. Сгенерируй: openssl rand -hex 32
# ВАЖНО: при потере ключа все сохранённые credentials в n8n станут нечитаемы.
N8N_ENCRYPTION_KEY=
