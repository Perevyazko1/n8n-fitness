# Скопируй в .env и заполни: cp .env.example .env

DOMAIN=n8n-fitness.ru

TZ=Europe/Moscow

# Ключ шифрования credentials. Сгенерируй: openssl rand -hex 32
# ВАЖНО: при потере ключа все сохранённые credentials в n8n станут нечитаемы.
N8N_ENCRYPTION_KEY=

# Токен Telegram-бота (из @BotFather). Нужен Code-ноде workflow
# Fitness_Bot_Barcode для валидации подписи initData от мини-аппа,
# а также Django-API для той же валидации.
TELEGRAM_BOT_TOKEN=

# Пароль регистрации новых пользователей бота. Новый юзер при первом старте
# должен прислать боту этот пароль — иначе бот молчит. Придумай сам.
REGISTRATION_PASSWORD=

# Секрет для cron-эндпоинтов Django (/api/cron/*). n8n-кроны шлют его в
# заголовке X-Cron-Secret — серверная авторизация без initData. openssl rand -hex 24
CRON_SECRET=

# --- Django Mini App API (сервисы db + api в docker-compose) ---
# Секрет Django: openssl rand -hex 32
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
# Postgres (контейнер db). Пароль придумай: openssl rand -hex 24
POSTGRES_DB=fitness
POSTGRES_USER=fitness
POSTGRES_PASSWORD=

# --- Платежи Platega (заготовка под подписку) ---
# Пока MERCHANT_ID/SECRET пустые — платежи ВЫКЛЮЧЕНЫ, приложение работает по флагу
# has_bot_access (как сейчас). Значения и host API возьми у менеджера Platega.
PLATEGA_API_BASE=https://app.platega.io
# Путь создания транзакции: метод-эндпоинт "/transaction/process" (с paymentMethod).
PLATEGA_PROCESS_PATH=/transaction/process
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
# Секрет входящего колбэка о статусе платежа (/api/payments/*). openssl rand -hex 24
PLATEGA_CALLBACK_SECRET=
# Куда вернуть плательщика после оплаты (страницы Mini App).
PUBLIC_BASE_URL=https://perevyazko1.github.io/n8n-fitness-scan
# Цена подписки в рублях и срок в днях.
SUBSCRIPTION_PRICE_RUB=299
SUBSCRIPTION_DAYS=30
# Способ оплаты по умолчанию: 2=СБП(QR), 3=ЕРИП, 11=карта, 12=межд., 13=крипта.
SUBSCRIPTION_PAYMENT_METHOD=2
