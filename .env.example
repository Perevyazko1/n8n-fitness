# Скопируй в .env и заполни: cp .env.example .env

DOMAIN=n8n-fitness.ru

TZ=Europe/Moscow

# Ключ шифрования credentials. Сгенерируй: openssl rand -hex 32
# ВАЖНО: при потере ключа все сохранённые credentials в n8n станут нечитаемы.
N8N_ENCRYPTION_KEY=

# Токен Telegram-бота (из @BotFather). Нужен Code-ноде workflow
# Fitness_Bot_Barcode для валидации подписи initData от мини-аппа,
# а также Django-API для той же валидации.
TELEGRAM_BOT_TOKEN=

# --- Django Mini App API (сервисы db + api в docker-compose) ---
# Секрет Django: openssl rand -hex 32
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
# Postgres (контейнер db). Пароль придумай: openssl rand -hex 24
POSTGRES_DB=fitness
POSTGRES_USER=fitness
POSTGRES_PASSWORD=
