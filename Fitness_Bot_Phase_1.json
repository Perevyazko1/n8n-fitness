    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\n// Достаём текстовый ответ модели из всех известных форматов:\n// - langchain openAi v2.3: { output: [{ content: [{ text: '...' }] }] }\n// - chat completions:      { message: { content: '...' } }\n// - простые варианты:       { content: '...' } | { text: '...' } | строка\nlet text =\n  raw?.output?.[0]?.content?.[0]?.text ??\n  raw?.message?.content ??\n  raw?.choices?.[0]?.message?.content ??\n  raw?.content ??\n  raw?.text ??\n  raw;\n\nif (typeof text !== 'string') {\n  text = JSON.stringify(text);\n}\n\n// Срезаем возможные ```json ... ``` обёртки, если модель всё-таки их добавила.\ntext = text.trim().replace(/^```(?:json)?\\s*/i, '').replace(/\\s*```$/,'').trim();\n\nlet payload;\ntry {\n  payload = JSON.parse(text);\n} catch (e) {\n  payload = { action: 'chat', data: {}, reply: text };\n}\n\nif (!payload || typeof payload !== 'object') {\n  payload = { action: 'chat', data: {}, reply: String(payload) };\n}\nif (!payload.action) payload.action = 'chat';\nif (!payload.data) payload.data = {};\nif (!payload.reply) payload.reply = '...';\n\nconst chat_id = $('Merge Text').item.json.chat_id;\nconst now = new Date();\nconst pad = (n) => String(n).padStart(2, '0');\nconst date = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}`;\nconst time = `${pad(now.getHours())}:${pad(now.getMinutes())}`;\n\nreturn [{ json: { ...payload, chat_id, date, time } }];"
      },
